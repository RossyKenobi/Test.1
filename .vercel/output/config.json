{
	"version": 3,
	"routes": [
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "^\\/_image$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/finalize-registration\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/migrate\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/posts\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/stacks\\/([^/]+?)\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/stacks\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/upload\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/api\\/verify-invite\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/finalize\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/sign-in\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/sign-up\\/?$",
			"dest": "_render"
		},
		{
			"src": "^\\/$",
			"dest": "_render"
		}
	]
}